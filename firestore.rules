rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net (Pillar 4 / Global Safety)
    match /{document=**} {
      allow read, write: if false;
    }

    // Common Helpers (Pillar 3)
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isStoreOwner() {
      return isSignedIn() && (
        request.auth.uid == "IDAyReIxa3Wqq0hPts3rIwzc3kw1" ||
        (request.auth.token != null && request.auth.token.email == "legendaryace590@gmail.com")
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    // Validation Blueprints (Pillar 2 / Schema Validation)
    function isValidCart(data) {
      return data.userId is string && data.userId.size() <= 128 &&
             data.items is list && data.items.size() <= 100 &&
             data.updatedAt is string && data.updatedAt.size() <= 64;
    }

    function isValidOrder(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.userId is string && data.userId.size() <= 128 &&
             data.date is string && data.date.size() <= 64 &&
             data.items is list && data.items.size() <= 100 &&
             data.subtotal is number &&
             data.discount is number &&
             data.shipping is number &&
             data.total is number &&
             data.shippingDetails is map &&
             data.status is string && data.status.size() <= 64;
    }

    // 1. Carts Collection (Pillar 6 / Identity Integrity)
    match /carts/{userId} {
      allow get: if isOwner(userId) || isStoreOwner();
      allow write: if (isOwner(userId) || isStoreOwner()) && isValidCart(incoming());
    }

    // 2. Orders Collection (Pillar 8 / Secure Query Enforcer)
    match /orders/{orderId} {
      allow create: if isSignedIn() && isValidOrder(incoming()) && (incoming().userId == request.auth.uid || isStoreOwner());
      allow get: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid || isStoreOwner());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isStoreOwner());
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || isStoreOwner()) && isValidOrder(incoming());
      allow delete: if isStoreOwner(); // Store owners can delete/purge orders if needed
    }

    // 3. Products Collection (Pillar 8)
    match /products/{productId} {
      allow read: if true; // Public catalog access
      allow write: if isSignedIn(); // Authorized store actions
    }
  }
}

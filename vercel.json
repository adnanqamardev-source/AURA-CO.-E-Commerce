{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/owner/verify-passcode",
      "destination": "/api/verify-passcode"
    },
    {
      "source": "/api/gemini/chat",
      "destination": "/api/gemini-chat"
    },
    {
      "source": "/api/payment/create-order",
      "destination": "/api/payment-create-order"
    },
    {
      "source": "/api/payment/verify",
      "destination": "/api/payment-verify"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
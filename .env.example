# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# AURA_OWNER_USERNAME: Custom secure username used to log into the Store Owner administrative panel.
# Defaults to "admin" if not defined here.
AURA_OWNER_USERNAME="admin"

# AURA_OWNER_PASSCODE: Custom secure key used to log into the Store Owner administrative panel.
# Defaults to "admin123" if not defined here.
AURA_OWNER_PASSCODE="admin123"

# RAZORPAY_KEY_ID: Razorpay API Key ID for processing orders.
RAZORPAY_KEY_ID=""

# RAZORPAY_KEY_SECRET: Razorpay API Key Secret for signature verification.
RAZORPAY_KEY_SECRET=""

# NODE_ENV: Application environment (development or production).
NODE_ENV="development"

# PORT: Port on which the local server runs.
PORT="3000"
